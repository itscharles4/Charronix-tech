generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  passwordHash        String               @map("password_hash")
  role                Role
  isActive            Boolean              @default(true) @map("is_active")
  lastLoginAt         DateTime?            @map("last_login_at")
  loginAttempts       Int                  @default(0) @map("login_attempts")
  lockedUntil         DateTime?            @map("locked_until")
  twoFactorEnabled    Boolean              @default(false) @map("two_factor_enabled")
  twoFactorSecret     String?              @map("two_factor_secret")
  profilePhotoUrl     String?              @map("profile_photo_url")
  preferences         Json?
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  loginId             String?              @unique @map("login_id")
  aiChatHistory       AiChatHistory[]
  auditLogs           AuditLog[]
  fileUploads         FileUpload[]
  notices             Notice[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  sessions            Session[]
  student             Student?
  systemSettings      SystemSetting[]
  teacher             Teacher?

  @@map("users")
}

model Student {
  id                   String             @id @default(uuid())
  userId               String?            @unique @map("user_id")
  admissionNo          String             @unique @map("admission_no")
  firstName            String             @map("first_name")
  lastName             String             @map("last_name")
  dateOfBirth          DateTime?          @map("date_of_birth")
  gender               String?
  class                String
  section              String
  rollNo               Int                @map("roll_no")
  parentName           String             @map("parent_name")
  parentPhone          String             @map("parent_phone")
  parentEmail          String?            @map("parent_email")
  status               StudentStatus      @default(ACTIVE)
  bloodGroup           String?            @map("blood_group")
  photoUrl             String?            @map("photo_url")
  address              String?
  totalPresent         Int                @default(0) @map("total_present")
  totalAbsent          Int                @default(0) @map("total_absent")
  attendancePercentage Float              @default(100) @map("attendance_percentage")
  lastAttendanceDate   DateTime?          @map("last_attendance_date")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  academicGrades       AcademicGrade[]
  achievements         Achievement[]
  attendance           Attendance[]
  communicationLogs    CommunicationLog[]
  complaints           Complaint[]
  medicalInfo          MedicalInfo?
  user                 User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  feeRecords           FeeRecord[]
  payments             Payment[]
  submissions          Submission[]

  @@index([class, section])
  @@index([status])
  @@index([admissionNo])
  @@map("students")
}

model Teacher {
  id               String            @id @default(uuid())
  userId           String?           @unique @map("user_id")
  employeeId       String            @unique @map("employee_id")
  firstName        String            @map("first_name")
  lastName         String            @map("last_name")
  phone            String
  email            String?
  qualification    String?
  dateOfJoining    DateTime?         @map("date_of_joining")
  isClassTeacherOf String?           @map("is_class_teacher_of")
  photoUrl         String?           @map("photo_url")
  status           String            @default("ACTIVE")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  academicGrades   AcademicGrade[]   @relation("EnteredBy")
  attendance       Attendance[]      @relation("MarkedBy")
  complaints       Complaint[]
  classes          TeacherClass[]
  subjects         TeacherSubject[]
  user             User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  timetableTeacher TimetableTeacher?
  assignments      Assignment[]

  @@map("teachers")
}

model TeacherSubject {
  id        String  @id @default(uuid())
  teacherId String  @map("teacher_id")
  subject   String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subject])
  @@map("teacher_subjects")
}

model TeacherClass {
  id           String  @id @default(uuid())
  teacherId    String  @map("teacher_id")
  classSection String  @map("class_section")
  teacher      Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classSection])
  @@map("teacher_classes")
}

model Attendance {
  id                  String           @id @default(uuid())
  studentId           String           @map("student_id")
  date                DateTime         @db.Date
  status              AttendanceStatus
  markedById          String?          @map("marked_by")
  remarks             String?
  location            Json?
  smsNotificationSent Boolean          @default(false) @map("sms_notification_sent")
  smsDeliveryStatus   String?          @map("sms_delivery_status")
  createdAt           DateTime         @default(now()) @map("created_at")
  markedBy            Teacher?         @relation("MarkedBy", fields: [markedById], references: [id])
  student             Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([date])
  @@index([status])
  @@map("attendance")
}

model AcademicGrade {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  subject      String
  score        Decimal  @db.Decimal(5, 2)
  maxScore     Decimal  @map("max_score") @db.Decimal(5, 2)
  grade        String?
  term         String
  academicYear String   @map("academic_year")
  enteredById  String?  @map("entered_by")
  createdAt    DateTime @default(now()) @map("created_at")
  enteredBy    Teacher? @relation("EnteredBy", fields: [enteredById], references: [id])
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subject, term, academicYear])
  @@map("academic_grades")
}

model Achievement {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  title       String
  date        DateTime @db.Date
  category    String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

model Complaint {
  id          String            @id @default(uuid())
  studentId   String            @map("student_id")
  teacherId   String?           @map("teacher_id")
  description String
  date        DateTime          @db.Date
  severity    ComplaintSeverity
  status      ComplaintStatus   @default(OPEN)
  createdAt   DateTime          @default(now()) @map("created_at")
  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher     Teacher?          @relation(fields: [teacherId], references: [id])

  @@map("complaints")
}

model MedicalInfo {
  id                String    @id @default(uuid())
  studentId         String    @unique @map("student_id")
  bloodGroup        String?   @map("blood_group")
  allergies         String[]
  chronicConditions String[]  @map("chronic_conditions")
  lastCheckup       DateTime? @map("last_checkup") @db.Date
  emergencyContact  String?   @map("emergency_contact")
  notes             String?
  updatedAt         DateTime  @updatedAt @map("updated_at")
  student           Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("medical_info")
}

model CommunicationLog {
  id        String            @id @default(uuid())
  studentId String            @map("student_id")
  date      DateTime          @db.Date
  type      CommunicationType
  note      String
  author    String
  createdAt DateTime          @default(now()) @map("created_at")
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("communication_logs")
}

model Notice {
  id            String         @id @default(uuid())
  title         String
  message       String
  target        String
  date          DateTime       @db.Date
  author        String
  smsSent       Boolean        @default(false) @map("sms_sent")
  type          NoticeType
  priority      NoticePriority @default(NORMAL)
  expiresAt     DateTime?      @map("expires_at")
  attachmentUrl String?        @map("attachment_url")
  readBy        Json?          @map("read_by")
  createdById   String?        @map("created_by")
  createdAt     DateTime       @default(now()) @map("created_at")
  createdBy     User?          @relation(fields: [createdById], references: [id])

  @@index([date])
  @@index([priority])
  @@map("notices")
}

model TimetableClass {
  id       String             @id @default(uuid())
  name     String
  entries  TimetableEntry[]
  sections TimetableSection[]

  @@map("timetable_classes")
}

model TimetableSection {
  id           String           @id @default(uuid())
  classId      String           @map("class_id")
  name         String
  studentCount Int              @default(0) @map("student_count")
  roomNumber   String?          @map("room_number")
  entries      TimetableEntry[]
  class        TimetableClass   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("timetable_sections")
}

model TimetableSubject {
  id              String                    @id @default(uuid())
  name            String
  code            String
  type            SubjectType
  periodsPerWeek  Int                       @map("periods_per_week")
  requiresLab     Boolean                   @default(false) @map("requires_lab")
  maxConsecutive  Int                       @default(2) @map("max_consecutive")
  preferredTime   String                    @default("any") @map("preferred_time")
  entries         TimetableEntry[]
  teacherSubjects TimetableTeacherSubject[]

  @@map("timetable_subjects")
}

model TimetableTeacher {
  id                String                     @id @default(uuid())
  teacherId         String?                    @unique @map("teacher_id")
  name              String
  level             Int?
  maxPeriodsPerDay  Int                        @default(6) @map("max_periods_per_day")
  maxPeriodsPerWeek Int                        @default(30) @map("max_periods_per_week")
  maxConsecutive    Int                        @default(3) @map("max_consecutive")
  entries           TimetableEntry[]
  subjects          TimetableTeacherSubject[]
  teacher           Teacher?                   @relation(fields: [teacherId], references: [id])
  unavailableSlots  TimetableUnavailableSlot[]

  @@map("timetable_teachers")
}

model TimetableTeacherSubject {
  id          String           @id @default(uuid())
  ttTeacherId String           @map("tt_teacher_id")
  ttSubjectId String           @map("tt_subject_id")
  ttSubject   TimetableSubject @relation(fields: [ttSubjectId], references: [id], onDelete: Cascade)
  ttTeacher   TimetableTeacher @relation(fields: [ttTeacherId], references: [id], onDelete: Cascade)

  @@unique([ttTeacherId, ttSubjectId])
  @@map("timetable_teacher_subjects")
}

model TimetableUnavailableSlot {
  id          String           @id @default(uuid())
  ttTeacherId String           @map("tt_teacher_id")
  day         String
  period      Int
  ttTeacher   TimetableTeacher @relation(fields: [ttTeacherId], references: [id], onDelete: Cascade)

  @@map("timetable_unavailable_slots")
}

model SchoolTiming {
  id             String             @id @default(uuid())
  startTime      DateTime           @map("start_time") @db.Time(6)
  endTime        DateTime           @map("end_time") @db.Time(6)
  periodsPerDay  Int                @map("periods_per_day")
  periodDuration Int                @map("period_duration")
  isActive       Boolean            @default(true) @map("is_active")
  breaks         SchoolBreak[]
  workingDays    SchoolWorkingDay[]

  @@map("school_timings")
}

model SchoolWorkingDay {
  id       String       @id @default(uuid())
  timingId String       @map("timing_id")
  dayName  String       @map("day_name")
  timing   SchoolTiming @relation(fields: [timingId], references: [id], onDelete: Cascade)

  @@map("school_working_days")
}

model SchoolBreak {
  id          String       @id @default(uuid())
  timingId    String       @map("timing_id")
  name        String
  afterPeriod Int          @map("after_period")
  duration    Int
  timing      SchoolTiming @relation(fields: [timingId], references: [id], onDelete: Cascade)

  @@map("school_breaks")
}

model GeneratedTimetable {
  id                 String           @id @default(uuid())
  score              Decimal?         @db.Decimal(5, 2)
  violations         String[]
  generatedAt        DateTime         @default(now()) @map("generated_at")
  isActive           Boolean          @default(false) @map("is_active")
  constraintSettings Json?            @map("constraint_settings")
  entries            TimetableEntry[]

  @@map("generated_timetables")
}

model TimetableEntry {
  id          String             @id @default(uuid())
  timetableId String             @map("timetable_id")
  classId     String?            @map("class_id")
  sectionId   String?            @map("section_id")
  day         String
  period      Int
  subjectId   String?            @map("subject_id")
  teacherId   String?            @map("teacher_id")
  class       TimetableClass?    @relation(fields: [classId], references: [id])
  section     TimetableSection?  @relation(fields: [sectionId], references: [id])
  subject     TimetableSubject?  @relation(fields: [subjectId], references: [id])
  teacher     TimetableTeacher?  @relation(fields: [teacherId], references: [id])
  timetable   GeneratedTimetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  @@map("timetable_entries")
}

model AiChatHistory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      String
  message   String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_chat_history")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  details   Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  device       String?
  ipAddress    String   @map("ip_address")
  lastActivity DateTime @default(now()) @map("last_activity")
  expiresAt    DateTime @map("expires_at")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("sessions")
}

model FileUpload {
  id         String   @id @default(uuid())
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  fileType   String   @map("file_type")
  fileSize   Int      @map("file_size")
  uploadedBy String   @map("uploaded_by")
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")
  uploader   User     @relation(fields: [uploadedBy], references: [id])

  @@index([entityType, entityId])
  @@index([uploadedBy])
  @@map("file_uploads")
}

model Notification {
  id           String               @id @default(uuid())
  userId       String               @map("user_id")
  title        String
  message      String
  type         NotificationType     @default(INFO)
  category     NotificationCategory @default(GENERAL)
  priority     NotificationPriority @default(NORMAL)
  isRead       Boolean              @default(false) @map("is_read")
  readAt       DateTime?            @map("read_at")
  actionUrl    String?              @map("action_url")
  iconEmoji    String?              @map("icon_emoji")
  senderUserId String?              @map("sender_user_id")
  senderName   String?              @map("sender_name")
  senderRole   String?              @map("sender_role")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([category])
  @@map("notifications")
}

model SystemSetting {
  id        String          @id @default(uuid())
  key       String          @unique
  value     String
  category  SettingCategory
  updatedBy String?         @map("updated_by")
  updatedAt DateTime        @updatedAt @map("updated_at")
  updater   User?           @relation(fields: [updatedBy], references: [id])

  @@index([category])
  @@map("system_settings")
}

model Timetable {
  id          String   @id @default(uuid())
  class       String
  section     String
  dayOfWeek   String   @map("day_of_week")
  period      Int
  periodTime  String   @map("period_time")
  subject     String
  teacherName String   @map("teacher_name")
  type        String   @default("CLASS")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([class, section, dayOfWeek, period])
  @@map("timetable")
}

enum Role {
  ADMIN
  PRINCIPAL
  TEACHER
  PARENT
  STUDENT
}

enum StudentStatus {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

enum ComplaintSeverity {
  LOW
  MEDIUM
  HIGH
}

enum ComplaintStatus {
  OPEN
  RESOLVED
  ESCALATED
}

enum NoticeType {
  GENERAL
  EVENT
  EXAM
}

enum NoticePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CommunicationType {
  SMS
  Call
  Meeting
  Portal
}

enum SubjectType {
  core
  elective
  activity
  language
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
  SYSTEM
}

enum NotificationCategory {
  ACADEMIC
  EVENT
  ANNOUNCEMENT
  ATTENDANCE
  EXAM
  FEE
  COMPLAINT
  GENERAL
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SettingCategory {
  SCHOOL
  EMAIL
  SMS
  AI
}

// ============================================
// FEE PAYMENT SYSTEM
// ============================================

enum FeeType {
  ACADEMIC
  TRANSPORT
  HOSTEL
  REGISTRATION
  LIBRARY
  EXAM
  MISCELLANEOUS
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  STRIPE
  PAYPAL
  CASH
  BANK_TRANSFER
}

model FeeStructure {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  feeType      FeeType  @map("fee_type")
  class        String
  academicYear String   @map("academic_year")

  amount      Float
  dueDate     DateTime @map("due_date")
  lateFee     Float    @default(0) @map("late_fee")
  discount    Float    @default(0)

  description String?
  isActive    Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  feeRecords FeeRecord[]

  @@unique([schoolId, feeType, class, academicYear])
  @@index([schoolId, class])
  @@map("fee_structures")
}

model FeeRecord {
  id             String   @id @default(uuid())
  studentId      String   @map("student_id")
  feeStructureId String   @map("fee_structure_id")

  feeType         FeeType       @map("fee_type")
  academicYear    String        @map("academic_year")
  totalAmount     Float         @map("total_amount")
  paidAmount      Float         @default(0) @map("paid_amount")
  remainingAmount Float         @map("remaining_amount")
  dueDate         DateTime      @map("due_date")

  status  PaymentStatus @default(PENDING)
  isPaid  Boolean       @default(false) @map("is_paid")

  isOverdue      Boolean @default(false) @map("is_overdue")
  lateFeeApplied Float   @default(0) @map("late_fee_applied")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  payments     Payment[]

  @@index([studentId])
  @@index([status])
  @@map("fee_records")
}

model Payment {
  id           String  @id @default(uuid())
  feeRecordId  String  @map("fee_record_id")
  studentId    String  @map("student_id")
  parentUserId String? @map("parent_user_id")

  amount        Float
  paymentMethod PaymentMethod @map("payment_method")
  transactionId String        @unique @map("transaction_id")
  receiptNumber String        @unique @map("receipt_number")

  gatewayOrderId   String? @map("gateway_order_id")
  gatewayPaymentId String? @map("gateway_payment_id")
  gatewaySignature String? @map("gateway_signature")
  gatewayResponse  Json?   @map("gateway_response")

  status  PaymentStatus @default(PENDING)
  paidAt  DateTime?     @map("paid_at")

  remarks    String?
  receiptUrl String? @map("receipt_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  feeRecord FeeRecord @relation(fields: [feeRecordId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@index([transactionId])
  @@index([gatewayOrderId])
  @@map("payments")
}

enum AssignmentStatus {
  ACTIVE
  EXPIRED
  DRAFT
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
  LATE
}

model Assignment {
  id              String   @id @default(uuid())
  teacherId       String   @map("teacher_id")
  
  // Assignment details
  title           String
  description     String   @db.Text
  subject         String
  class           String
  section         String?  // Optional: null means all sections
  
  // Files
  attachmentUrl   String?  @map("attachment_url") // URL to assignment file
  attachmentName  String?  @map("attachment_name")
  attachmentSize  Int?     @map("attachment_size") // in bytes
  
  // Deadline
  dueDate         DateTime @map("due_date")
  allowLateSubmission Boolean @default(true) @map("allow_late_submission")
  
  // Grading
  maxMarks        Int?     @map("max_marks")
  
  // Metadata
  status          AssignmentStatus @default(ACTIVE)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  teacher         Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  submissions     Submission[]
  
  @@index([teacherId])
  @@index([class, section])
  @@index([status])
  @@map("assignments")
}

model Submission {
  id              String   @id @default(uuid())
  assignmentId    String   @map("assignment_id")
  studentId       String   @map("student_id")
  
  // Submission files
  attachmentUrl   String?  @map("attachment_url")
  attachmentName  String?  @map("attachment_name")
  attachmentSize  Int?     @map("attachment_size")
  
  // Status
  status          SubmissionStatus @default(PENDING)
  isLate          Boolean  @default(false) @map("is_late")
  submittedAt     DateTime? @map("submitted_at")
  
  // Grading
  marksObtained   Int?     @map("marks_obtained")
  feedback        String?  @db.Text
  gradedAt        DateTime? @map("graded_at")
  gradedBy        String?  @map("graded_by")
  
  // Metadata
  remarks         String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  assignment      Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student         Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([status])
  @@map("submissions")
}
