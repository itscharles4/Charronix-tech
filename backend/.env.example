# ============================================
# SERVER
# ============================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ============================================
# DATABASE (matches docker-compose.yml defaults)
# ============================================
DATABASE_URL=postgresql://charronix_user:charronix_pass_2024@localhost:5432/charronix_db
DIRECT_URL=postgresql://charronix_user:charronix_pass_2024@localhost:5432/charronix_db

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# JWT
# ============================================
JWT_SECRET=change-this-to-a-random-32-char-secret-key
JWT_REFRESH_SECRET=change-this-to-another-random-32-char-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# FRONTEND
# ============================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# FILE UPLOADS
# ============================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# ============================================
# GOOGLE AI
# ============================================
GOOGLE_AI_API_KEY=your-google-genai-api-key-here
GOOGLE_AI_MODEL=gemini-1.5-flash

# ============================================
# TWILIO (SMS) - optional
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_ENABLED=false

# ============================================
# EMAIL (SMTP) - optional
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=Charronix School <noreply@charronix.com>
EMAIL_ENABLED=false

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# SECURITY
# ============================================
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
